# ─────────────────────────────────────────────────────────────
#  .env.prod.example — Variáveis de ambiente de produção
#
#  Arquitetura: Oracle Cloud x86 VMs + Neon + Vercel
#  VM1: Backend API  |  VM2: Evolution API  |  DB: Neon
#
#  Copie para .env.prod e preencha TODOS os campos
#  NUNCA commite .env.prod no git!
# ─────────────────────────────────────────────────────────────

# ── Domínios ──────────────────────────────────────────────────
# VM1: domínio para a API backend (ex: api.seudominio.com)
API_DOMAIN=api.seudominio.com

# VM2: domínio para o Evolution API/WhatsApp (ex: wa.seudominio.com)
EVO_DOMAIN=wa.seudominio.com

# Email para Let's Encrypt (certificados SSL gratuitos)
CERTBOT_EMAIL=seu@email.com

# ── Database — Neon PostgreSQL (gratuito para sempre) ─────────
# Obtenha em: https://neon.tech → New Project → Connection string
# Formato: postgresql://user:pass@host.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://clinicai:SENHA@ep-xxx.sa-east-1.aws.neon.tech/clinic_sas?sslmode=require

# Evolution API usa um database separado no mesmo Neon project
# Crie um branch ou database "evolution_api" no Neon
EVOLUTION_DB_URL=postgresql://clinicai:SENHA@ep-xxx.sa-east-1.aws.neon.tech/evolution_api?sslmode=require

# ── Redis (local na VM2 — apenas sessões WhatsApp) ────────────
REDIS_PASSWORD=TROQUE_POR_SENHA_REDIS_FORTE

# ── Autenticação JWT ──────────────────────────────────────────
# Gere com: openssl rand -hex 64
JWT_SECRET=GERE_UM_SEGREDO_LONGO_AQUI_64_CHARS

# ── Bootstrap do superadmin ───────────────────────────────────
ADMIN_BOOTSTRAP_SECRET=SEGREDO_BOOTSTRAP_AQUI

# ── AI — OpenRouter (gratuito com modelos free) ───────────────
# Cadastre em: https://openrouter.ai
AI_INTEGRATIONS_OPENAI_API_KEY=sk-or-v1-SUA_CHAVE_OPENROUTER_AQUI

# ── AI — Groq (fallback gratuito) ────────────────────────────
# Cadastre em: https://console.groq.com
GROQ_API_KEY=gsk_SUA_CHAVE_GROQ_AQUI

# ── Evolution API (WhatsApp) ──────────────────────────────────
EVOLUTION_API_KEY=CHAVE_EVOLUTION_FORTE_AQUI

# URL pública da VM2 (onde o Evolution API está hospedado)
EVOLUTION_API_URL=https://wa.seudominio.com

# URL pública da VM2 (para configuração interna do Evolution)
EVOLUTION_PUBLIC_URL=https://wa.seudominio.com

# URL para webhook do Evolution → VM1 API
# Deve ser a URL pública da VM1
EVOLUTION_WEBHOOK_URL=https://api.seudominio.com

# ── CORS — Frontend Vercel ────────────────────────────────────
# URL do seu deploy no Vercel (ou domínio customizado)
# Separe múltiplos por vírgula
ALLOWED_ORIGINS=https://seuapp.vercel.app,https://seudominio.com

# ── Servidor ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Mercado Pago (opcional) ───────────────────────────────────
MERCADO_PAGO_ACCESS_TOKEN=
