# ─────────────────────────────────────────────────────────────
#  .env.prod.example — Variáveis de ambiente de produção
#  Copie para .env.prod e preencha TODOS os campos
#  NUNCA commite .env.prod no git!
# ─────────────────────────────────────────────────────────────

# ── Domínio ──────────────────────────────────────────────────
DOMAIN=seu-dominio.com
CERTBOT_EMAIL=seu@email.com

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_USER=clinicai
POSTGRES_PASSWORD=TROQUE_POR_SENHA_FORTE_AQUI
POSTGRES_DB=clinic_sas

# DATABASE_URL usada pelo backend e pelo drizzle-kit
# Dentro do Docker Compose, o host é "postgres" (nome do serviço)
DATABASE_URL=postgresql://clinicai:TROQUE_POR_SENHA_FORTE_AQUI@postgres:5432/clinic_sas

# ── Redis ─────────────────────────────────────────────────────
REDIS_PASSWORD=TROQUE_POR_SENHA_REDIS_AQUI

# ── Autenticação JWT ──────────────────────────────────────────
# Gere com: openssl rand -hex 64
JWT_SECRET=GERE_UM_SEGREDO_LONGO_AQUI

# ── Bootstrap do superadmin ───────────────────────────────────
# Segredo usado uma única vez em POST /api/admin/bootstrap
ADMIN_BOOTSTRAP_SECRET=SEGREDO_BOOTSTRAP_AQUI

# ── AI — OpenRouter ───────────────────────────────────────────
AI_INTEGRATIONS_OPENAI_API_KEY=sk-or-v1-SUA_CHAVE_OPENROUTER_AQUI

# ── AI — Groq (fallback) ──────────────────────────────────────
GROQ_API_KEY=gsk_SUA_CHAVE_GROQ_AQUI

# ── Evolution API (WhatsApp) ──────────────────────────────────
# Chave de autenticação do Evolution Manager
EVOLUTION_API_KEY=CHAVE_EVOLUTION_FORTE_AQUI

# URL interna do Evolution (dentro do Docker, serviço "evolution")
EVOLUTION_API_URL=http://evolution:8080

# URL pública do webhook (onde o Evolution chama de volta o backend)
# Deve ser acessível de dentro do container Evolution
EVOLUTION_WEBHOOK_URL=https://seu-dominio.com

# ── Mercado Pago (opcional) ───────────────────────────────────
# Deixe em branco para desabilitar pagamentos PIX
MERCADO_PAGO_ACCESS_TOKEN=

# ── Servidor ─────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Backup ───────────────────────────────────────────────────
BACKUP_DIR=/opt/clinicai/backups
BACKUP_RETENTION_DAYS=7
