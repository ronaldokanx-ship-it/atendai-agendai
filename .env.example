# =============================================================================
# Banco de Dados
# =============================================================================
# String de conexão PostgreSQL
DATABASE_URL=postgresql://postgres:sua_senha@localhost:5433/clinic_sas

# =============================================================================
# OpenAI / Gemini
# =============================================================================
AI_INTEGRATIONS_OPENAI_API_KEY=sk-...
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1

# =============================================================================
# API Server (artifacts/api-server)
# =============================================================================
PORT=3000
API_PORT=3000

# =============================================================================
# Evolution API — WhatsApp Business (docker-compose.evolution.yml)
# =============================================================================
# URL da Evolution API (padrão: porta 8080 no Docker)
EVOLUTION_API_URL=http://localhost:8080
# Chave de autenticação da Evolution API (AUTHENTICATION_API_KEY no docker-compose)
EVOLUTION_API_KEY=evo-key-change-me-in-production

# =============================================================================
# Frontend - clinic-dashboard (artifacts/clinic-dashboard)
# =============================================================================
# PORT=5173
# BASE_PATH=/
